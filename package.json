{
  "name": "encore-karaoke",
  "version": "1.3.1",
  "description": "Turn your PC into a karaoke machine, complete with scoring and recording features. For karaoke fans, by karaoke fans. Runs offline.",
  "main": "main.js",
  "scripts": {
    "build": "node build.js",
    "build:dev": "node build.js --dev",
    "start": "npm run build:dev && electron-forge start -- --dev",
    "package": "npm run build && electron-forge package",
    "make": "npm run build && electron-forge make"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Encore-Karaoke-Labs/Encore-Karaoke"
  },
  "keywords": [
    "htpc",
    "web-os",
    "movies",
    "tv"
  ],
  "author": "Encore Karaoke Labs",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Encore-Karaoke-Labs/Encore-Karaoke/issues"
  },
  "homepage": "./",
  "dependencies": {
    "@xhayper/discord-rpc": "^1.2.0",
    "bonjour-service": "^1.3.0",
    "cors": "^2.8.5",
    "electron-squirrel-startup": "^1.0.1",
    "express": "^4.19.2",
    "kuroshiro": "^1.2.0",
    "kuroshiro-analyzer-kuromoji": "^1.1.0",
    "localforage": "^1.10.0",
    "loudness": "^0.4.2",
    "mime-types": "^2.1.35",
    "pitchy": "^4.1.0",
    "qrcode": "^1.5.3",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.8.3",
    "spessasynth_core": "^4.2.13",
    "spessasynth_lib": "^4.2.15",
    "systeminformation": "^5.31.1",
    "youtube-search-api": "^2.0.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.4.0",
    "@electron-forge/maker-deb": "^7.4.0",
    "@electron-forge/maker-rpm": "^7.4.0",
    "@electron-forge/maker-squirrel": "^7.4.0",
    "@electron-forge/maker-zip": "^7.4.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.4.0",
    "@electron-forge/plugin-fuses": "^7.4.0",
    "@electron/fuses": "^1.8.0",
    "electron": "^41.2.0",
    "electron-winstaller": "^5.4.0",
    "esbuild": "0.28.0"
  }
}
